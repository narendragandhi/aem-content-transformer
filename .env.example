AEM_OUTPUT_PATH=./output
AEM_PACKAGE_NAME=content-migration
AEM_SITE_PATH=/content/mysite
AEM_TEMPLATE_PATH=/conf/mysite/settings/wcm/templates/content-page
AEM_DESIGN_PATH=

# Packaging
AEM_PACKAGE_ZIP=false
AEM_FILEVAULT_ENABLED=false
AEM_FILEVAULT_COMMAND=vault
AEM_FILEVAULT_VALIDATE=false

# HTML sanitization policy
AEM_HTML_POLICY=relaxed
# If using custom policy:
AEM_HTML_ALLOWED_TAGS=p,br,strong,em,ul,ol,li,a,blockquote,pre,code,h1,h2,h3
AEM_HTML_ALLOWED_ATTRS=a.href,a.title,a.target,a.rel
AEM_HTML_ALLOWED_PROTOCOLS=a.href:https|http|mailto

# AEM template governance
AEM_ALLOWED_TEMPLATES=
AEM_CLOUDSERVICE_CONFIGS=

# Tags
AEM_TAGS_ROOT=/content/cq:tags/mysite

# Asset ingestion
AEM_ASSET_DOWNLOAD=true
AEM_ASSET_MAX_BYTES=52428800
AEM_ASSET_RETRY_MAX=3
AEM_ASSET_RETRY_DELAY_MS=1000
AEM_ASSET_DOWNLOAD_DELAY_MS=0
AEM_ASSET_UPLOAD_DELAY_MS=0
AEM_ASSET_API_ENABLED=false
AEM_ASSET_API_UPLOAD_URL=
AEM_ASSET_API_AUTH_TYPE=basic
AEM_ASSET_API_AUTH_USER=
AEM_ASSET_API_AUTH_PASSWORD=
AEM_ASSET_API_AUTH_TOKEN=
AEM_ASSET_API_VERIFY_ENABLED=false
AEM_ASSET_API_VERIFY_URL=
AEM_ASSET_API_VERIFY_TIMEOUT_MS=60000
AEM_ASSET_API_VERIFY_INTERVAL_MS=2000

# Rate limiting (0 disables)
WP_RPS=0
AEM_RPS=0

# Fragments
AEM_FRAGMENTS_ENABLED=false
AEM_FRAGMENT_MODEL=/conf/mysite/settings/dam/cfm/models/article
AEM_FRAGMENT_DAM_PATH=/content/dam/mysite/fragments
AEM_XF_PATH=/content/experience-fragments/mysite
AEM_XF_TEMPLATE=/conf/mysite/settings/wcm/templates/experience-fragment
AEM_EMBED_XF_ON_PAGE=false

# AEM validation (optional)
AEM_VALIDATION_ENABLED=false
AEM_VALIDATION_BASE_URL=
AEM_VALIDATION_HEALTH_PATH=/system/health.json
AEM_VALIDATION_AUTH_TYPE=basic
AEM_VALIDATION_AUTH_USER=
AEM_VALIDATION_AUTH_PASSWORD=
AEM_VALIDATION_AUTH_TOKEN=
AEM_VALIDATION_EXTRA_PATHS=

# WordPress tag warmup
WP_TAG_WARMUP_ENABLED=false
WP_TAG_WARMUP_PER_PAGE=100
WP_TAG_WARMUP_MAX_PAGES=10

# Migration controls
MIGRATION_CHECKPOINT_ENABLED=true
MIGRATION_CHECKPOINT_INTERVAL=100
MIGRATION_CHECKPOINT_PATH=./output/checkpoint.json
MIGRATION_RETRY_FAILED=true
MIGRATION_SKIP_OUTPUT_CHECK=false
MIGRATION_MANIFEST_FILENAME=manifest.jsonl
MIGRATION_DLQ_FILENAME=dlq.jsonl
MIGRATION_REPORT_PATH=./output/report.json
MIGRATION_DELTA_SINCE=
MIGRATION_PARITY_ENABLED=true
MIGRATION_PARITY_FILENAME=parity.jsonl
